              "margin-right": "1.5rem"
            },
            ".nav-link, .nav-link.active": {
              "padding": "1rem 0",
              "background-color": "transparent"
            },
            ".nav-tabs .nav-link.active": {
              "color": "@activeColor",
              "border-bottom": "3px solid @activeColor"
            },
            "H4": {
              "text-align": "center"
            },
            "H3": {
              "text-align": "center"
            }
          },
          "_name": "tabs1",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"tabs content18\" group=\"Content\" data-bg-video=\"{{bg.type == 'video'&&bg.value.url}}\" mbr-class=\"{'mbr-parallax-background':bg.parallax}\" plugins=\"mbr-tabs\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" name=\"fullWidth\" title=\"Full Width\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" value=\"8\" step=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <header>Tabs</header>\n        <select title=\"Count\" name=\"bootstrapTabs\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\" selected>4</option>\n            <option value=\"5\">5</option>\n            <option value=\"6\">6</option>\n        </select>\n        <input type=\"color\" name=\"tabsColor\" title=\"Color\" value=\"#000000\">\n        <input type=\"color\" name=\"activeColor\" title=\"Active Color\" value=\"#813131\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#b86f6f\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/background13.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay&&bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay&&bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay&&bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\" mbr-if=\"showTitle || showSubtitle\">\n            <div class=\"col-12 col-md-{{textWidth}}\">\n                <h3 class=\"mbr-section-title mb-0 mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                    <b>Статьи</b></h3>\n                <h4 class=\"mbr-section-subtitle mb-0 mt-2 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showSubtitle\">Tabs Subtitle</h4>\n            </div>\n        </div>\n        <div class=\"row justify-content-center mt-4\">\n            <div class=\"col-12 col-md-{{textWidth}}\">\n                <ul class=\"nav nav-tabs mb-4\" role=\"tablist\">\n                    <li mbr-buttons mbr-theme-style=\"display-7\" class=\"nav-item first mbr-fonts-style\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\"><a class=\"nav-link mbr-fonts-style show active\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tabs1-1e_tab0\" data-app-placeholder=\"Введите Текст\" aria-selected=\"true\"><strong>Идеи подарков для мужчин: практичные и стильные решения</strong></a></li>\n                    <li mbr-buttons mbr-theme-style=\"display-7\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 1\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\"><a class=\"nav-link mbr-fonts-style active\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tabs1-1e_tab1\" data-app-placeholder=\"Введите Текст\" aria-selected=\"true\"><strong>Как выбрать качественные кожаные аксессуары</strong></a></li>\n                    <li mbr-buttons mbr-theme-style=\"display-7\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 2\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\"><a class=\"nav-link mbr-fonts-style active\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tabs1-1e_tab2\" data-app-placeholder=\"Введите Текст\" aria-selected=\"true\"><strong>Топ ошибок в мужском стиле</strong><br></a></li>\n                    <li mbr-buttons mbr-theme-style=\"display-7\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 3\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\"><a class=\"nav-link mbr-fonts-style active\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tabs1-1e_tab3\" data-app-placeholder=\"Введите Текст\" aria-selected=\"true\"><strong>Как собрать стильный мужской образ&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;</strong></a></li>\n                    <li mbr-buttons mbr-theme-style=\"display-7\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 4\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\">\n                        <a class=\"nav-link mbr-fonts-style\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tab5\" data-app-placeholder=\"Type Text\" aria-selected=\"true\">\n                            <b>Design</b>\n                        </a>\n                    </li>\n                    <li mbr-buttons mbr-theme-style=\"display-7\" class=\"nav-item\" mbr-if=\"bootstrapTabs > 5\" data-toolbar=\"-mbrBtnAdd,-mbrBtnMove,-mbrLink,-mbrBtnRemove,-iconFont\">\n                        <a class=\"nav-link mbr-fonts-style\" role=\"tab\" data-toggle=\"tab\" data-bs-toggle=\"tab\" href=\"#tab6\" data-app-placeholder=\"Type Text\" aria-selected=\"true\">\n                            <b>Architecture</b>\n                        </a>\n                    </li>\n                </ul>\n                <div class=\"tab-content\">\n                    <div id=\"tab1\" class=\"tab-pane in active\" role=\"tabpanel\">\n                        <div class=\"row\">\n                            <div class=\"col-md-12\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\">Выбор подарка для мужчины часто вызывает сложности: хочется подобрать что-то полезное, стильное и универсальное, но при этом не ошибиться. Многие подарки оказываются слишком банальными или не используются в повседневной жизни. Особенно сложно найти вариант, который подойдет по стилю и будет действительно востребован.<br><br>Практичное решение — это вещи, которые используются ежедневно и всегда актуальны. Сорочки и брюки подходят для работы и повседневной жизни, галстуки, шарфы и кашне дополняют образ, а кожаные аксессуары — портмане, клатчи, сумки, ремни и ключницы — становятся постоянной частью гардероба. Такие подарки не только полезны, но и подчеркивают внимание к деталям.<br><br>Главное преимущество таких решений — универсальность. Они подходят большинству мужчин, легко вписываются в любой стиль и служат долго. Это сочетание практичности и эстетики, которое всегда ценится. Ознакомьтесь с каталогом и выберите сорочки, сумки, портмане или ремни, которые станут действительно удачным и продуманным подарком.<br></p>\n                            </div>\n                        </div>\n                    </div>\n                    <div id=\"tab2\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 1\">\n                        <div class=\"row\">\n                            <div class=\"col-md-12\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\">Выбор кожаных аксессуаров кажется простым, но на практике многие сталкиваются с разочарованием: сумки теряют форму, портмане быстро изнашиваются, а ремни начинают выглядеть неаккуратно уже через короткое время. На первый взгляд изделия могут казаться качественными, но при ежедневном использовании проявляются слабые материалы и недостатки пошива. В итоге приходится снова искать замену, тратя время и деньги.<br><br>Правильный выбор — это кожаные аксессуары, которые изначально рассчитаны на длительное использование. Сумки должны быть удобными и универсальными, чтобы подходить как для работы, так и для повседневной жизни. Портмане и клатчи должны быть практичными, с продуманной внутренней организацией, а ремни и ключницы — надежными и устойчивыми к износу. Когда аксессуары выполнены из качественных материалов, они сохраняют внешний вид и выглядят аккуратно даже спустя длительное время.<br><br>Качественные кожаные изделия — это не просто дополнение, а важная часть образа. Они подчеркивают статус, делают внешний вид более собранным и избавляют от необходимости часто менять вещи. Это разумное вложение в стиль и комфорт. Ознакомьтесь с ассортиментом и выберите сумки, портмане, ремни или ключницы, которые будут служить вам долго и подчеркивать ваш стиль каждый день.</p>\n                            </div>\n                        </div>\n                    </div>\n                    <div id=\"tab3\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 2\">\n                        <div class=\"row\">\n                            <div class=\"col-md-12\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\">Даже при наличии хорошей одежды мужской стиль может выглядеть неаккуратно из-за типичных ошибок. Часто мужчины выбирают сорочки и брюки, не учитывая, как они сочетаются, добавляют слишком яркие или неподходящие галстуки или полностью игнорируют аксессуары. Также распространена ошибка — использование некачественных шарфов или кашне, которые портят общее впечатление. В итоге даже дорогие вещи не создают желаемого эффекта.<br><br>Избежать этих проблем можно, если придерживаться простого и логичного подхода. Базовые сорочки и брюки должны быть основой гардероба, а галстуки, шарфы и кашне — дополнять образ, а не перегружать его. Аксессуары, такие как ремни, сумки и портмане, должны быть качественными и подходить по стилю к остальным элементам. Важно выбирать вещи, которые легко комбинируются между собой, чтобы каждый элемент усиливал общий образ.<br><br>Когда вы избегаете этих ошибок, внешний вид становится более аккуратным и продуманным. Вы начинаете выглядеть уверенно, даже не прикладывая дополнительных усилий, а ваш стиль становится стабильным и узнаваемым. Подберите сорочки, брюки, галстуки и аксессуары, которые уже сочетаются между собой, и создайте гармоничный образ без лишних экспериментов.</p>\n                            </div>\n                        </div>\n                    </div>\n                    <div id=\"tab4\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 3\">\n                        <div class=\"row\">\n                            <div class=\"col-md-12\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\">Многие мужчины сталкиваются с проблемой: даже при наличии хороших вещей сложно собрать стильный образ, в котором сорочки, брюки и аксессуары смотрятся гармонично. Часто одежда покупается отдельно, без понимания, как она будет сочетаться, из-за чего сорочки не подходят к брюкам, галстуки выглядят случайно, а шарфы или кашне выбиваются из общего стиля. В результате образ кажется неаккуратным, даже если сами вещи качественные.<br><br>Решение этой проблемы — формирование продуманного мужского гардероба, где каждая деталь дополняет другую. Базовые сорочки нейтральных цветов легко сочетаются с брюками разных оттенков, а правильно подобранные галстуки и кашне добавляют акцент, не перегружая образ. Важную роль играют аксессуары: ремни, сумки и даже такие детали, как ключницы, помогают создать завершенный и аккуратный внешний вид. Когда гардероб собран грамотно, вам не нужно каждый раз тратить время на подбор — всё уже работает вместе.<br><br>Такой подход дает ощутимые преимущества: вы всегда выглядите уверенно, экономите время и создаете впечатление человека, который следит за деталями. Это важно не только в деловой среде, но и в повседневной жизни, где внешний вид формирует первое впечатление. Ознакомьтесь с каталогом и подберите сорочки, брюки, галстуки, сумки и ремни, которые помогут вам создать стильный и продуманный образ без лишних усилий.</p>\n                            </div>\n                        </div>\n                    </div>\n                    <div id=\"tab5\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 4\">\n                        <div class=\"row\">\n                            <div class=\"col-md-12\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\">\n                                    Free Website Builder offers a huge collection of 2500+ website blocks, templates and\n                                    themes with thousands flexible options. Combine blocks from different themes to\n                                    create a unique mix.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                    <div id=\"tab6\" class=\"tab-pane\" role=\"tabpanel\" mbr-if=\"bootstrapTabs > 5\">\n                        <div class=\"row\">\n                            <div class=\"col-md-12\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\">\n                                    Free Website Builder offers a huge collection of 2500+ website blocks, templates and\n                                    themes with thousands flexible options. Combine blocks from different themes to\n                                    create a unique mix.</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_anchor": "tabs1-1e",
